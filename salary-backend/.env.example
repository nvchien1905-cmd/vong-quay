# ============================================================
# CẤU HÌNH SERVER
# ============================================================
PORT=3000
NODE_ENV=development

# ============================================================
# CORS - Danh sách domain được phép truy cập API
# Nhiều domain: http://localhost:3000,https://your-domain.com
# Cho phép tất cả: *  (không khuyến khích trên production)
# ============================================================
CORS_ORIGIN=http://localhost:3000

# ============================================================
# LOG LEVEL: error | warn | info | debug
# ============================================================
LOG_LEVEL=info

# ============================================================
# KIOTVIET API CREDENTIALS
# Lấy tại: https://developer.kiotviet.vn/
# ============================================================

# Client ID từ KiotViet Developer Portal
KIOTVIET_CLIENT_ID=your_client_id_here

# Client Secret từ KiotViet Developer Portal
KIOTVIET_CLIENT_SECRET=your_client_secret_here

# Mã cửa hàng (Retailer Code) - thường là subdomain KiotViet của bạn
KIOTVIET_RETAILER_CODE=your_retailer_code_here

# Base URL của KiotViet Public API (không thay đổi trừ khi có hướng dẫn khác)
KIOTVIET_BASE_URL=https://public.kiotapi.com
